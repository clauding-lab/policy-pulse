{
  "manifest_version": 3,
  "name": "Policy Pulse Clipper",
  "version": "1.0.0",
  "description": "Clip Bangladesh Bank circulars from bb.org.bd and send to Policy Pulse",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://www.bb.org.bd/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
